{
  "name": "compodocs",
  "version": "1.0.0",
  "description": "Generate JSDoc for React components by analyzing their props.",
  "type": "module",
  "bin": {
    "compodocs": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run test && npm run build",
    "prepack": "npm run build",
    "test": "vitest --run",
    "format": "prettier --write --cache ."
  },
  "keywords": [
    "cli",
    "documentation",
    "jsdoc",
    "react",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "ts-morph": "^27.0.2",
    "tsconfck": "^3.1.6",
    "unconfig": "^7.4.2",
    "zod": "^4.1.13"
  }
}
